---
import { Image } from "astro:assets";
import heroImage from "../../assets/domonor-hero.png";
import logoTwoA from "../../assets/2a.svg";
import logoOneB from "../../assets/1b.svg";
import portraitImage from "../../assets/Portrait.png";
import { siteContent, type Locale } from "../content/site";
import ContactForm from "./ContactForm.vue";
import SiteHeader from "./SiteHeader.vue";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = siteContent[locale];
const year = new Date().getFullYear();
---

<div class="site-shell" data-locale={locale}>
  <SiteHeader client:load nav={t.nav} language={t.language} contactLabel={t.hero.primary} logoSources={[logoTwoA.src, logoOneB.src]} />

  <main id="top">
    <section class="hero-section" aria-labelledby="hero-title">
      <div class="hero-media" aria-hidden="true">
        <Image src={heroImage} alt="" loading="eager" widths={[900, 1400, 1800]} sizes="100vw" />
      </div>
      <div class="hero-light" aria-hidden="true"></div>
      <div class="hero-scrim"></div>
      <div class="hero-inner">
        <div class="hero-copy reveal">
          {t.hero.eyebrow && <p class="eyebrow">{t.hero.eyebrow}</p>}
          <h1 id="hero-title">{t.hero.headline}</h1>
          <p class="hero-subline">{t.hero.subline}</p>
          <div class="hero-actions">
            <a class="button button-primary" href="#contact">{t.hero.primary}</a>
            <a class="button button-glass" href="#solutions">{t.hero.secondary}</a>
          </div>
        </div>
        {t.hero.status && <p class="hero-status reveal">{t.hero.status}</p>}
      </div>
    </section>

    <section class="intro-section" aria-labelledby="intro-title">
      <div class="intro-kicker reveal">{t.intro.kicker}</div>
      <div class="intro-grid">
        <h2 id="intro-title" class="reveal">{t.intro.title}</h2>
        <p class="large-copy reveal">{t.intro.body}</p>
      </div>
    </section>

    <section class="solutions-section" id="solutions" aria-labelledby="solutions-title">
      <div class="section-heading reveal">
        <p class="eyebrow">{t.solutions.eyebrow}</p>
        <h2 id="solutions-title">{t.solutions.title}</h2>
        <p>{t.solutions.body}</p>
      </div>
      <div class="solutions-grid">
        {t.solutions.items.map((item, index) => (
          <article class="solution-card reveal" style={`--delay: ${index * 90}ms`}>
            <div>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="partner-section" id="partner" aria-labelledby="partner-title">
      <div class="partner-sticky">
        <div class="partner-orb" aria-hidden="true"></div>
        <div class="partner-copy reveal">
          <p class="eyebrow">{t.partner.eyebrow}</p>
          <h2 id="partner-title">{t.partner.title}</h2>
          <p>{t.partner.body}</p>
          <a class="button button-dark" href="#contact">{t.partner.cta}</a>
        </div>
        <div class="partner-panel reveal" aria-label={t.partner.eyebrow}>
          {t.partner.points.map((point) => <span>{point}</span>)}
        </div>
      </div>
    </section>

    <section class="founder-section" id="founder" aria-labelledby="founder-title">
      <div class="founder-image reveal">
        <Image src={portraitImage} alt={t.founder.title} widths={[420, 620, 900]} sizes="(max-width: 820px) 90vw, 38vw" />
      </div>
      <div class="founder-copy reveal">
        <p class="eyebrow">{t.founder.eyebrow}</p>
        <h2 id="founder-title">{t.founder.title}</h2>
        <p class="founder-role">{t.founder.role}</p>
        <a class="founder-email" href={`mailto:${t.founder.email}`}>{t.founder.email}</a>
        <p>{t.founder.body}</p>
        {t.founder.details.length > 0 && (
          <div class="detail-row">
            {t.founder.details.map((detail) => <span>{detail}</span>)}
          </div>
        )}
      </div>
    </section>

    <section class="contact-section" id="contact" aria-labelledby="contact-title">
      <div class="contact-copy reveal">
        <p class="eyebrow">{t.contact.eyebrow}</p>
        <h2 id="contact-title">{t.contact.title}</h2>
        <p>{t.contact.body}</p>
      </div>
      <ContactForm client:load contact={t.contact} />
    </section>
  </main>

  <footer class="site-footer">
    <span>© {year} Domonor</span>
    <span>{t.footer}</span>
  </footer>
</div>

<script>
  const revealNodes = document.querySelectorAll<HTMLElement>(".reveal");
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
        }
      });
    },
    { threshold: 0.14 },
  );

  revealNodes.forEach((node) => observer.observe(node));

  const updateScroll = () => {
    const max = document.documentElement.scrollHeight - window.innerHeight;
    const progress = max > 0 ? window.scrollY / max : 0;
    const heroHeight = document.querySelector<HTMLElement>(".hero-section")?.offsetHeight ?? window.innerHeight;
    const heroProgress = Math.min(Math.max(window.scrollY / heroHeight, 0), 1);
    document.documentElement.style.setProperty("--scroll-progress", progress.toFixed(4));
    document.documentElement.style.setProperty("--hero-progress", heroProgress.toFixed(4));
  };

  updateScroll();
  window.addEventListener("scroll", updateScroll, { passive: true });
</script>
